# ============================================================
# クリプト取引履歴トラッカー - API キー設定
# ============================================================
# このファイルをコピーして ".env" という名前で保存し、
# 各APIキーを設定してください。
# cp .env.example .env
# ============================================================

# Basescan API Key (Base ネットワーク)
# 取得先: https://basescan.org/myapikey  (無料登録)
BASESCAN_API_KEY=your_basescan_api_key_here

# Polygonscan API Key (Polygon ネットワーク)
# 取得先: https://polygonscan.com/myapikey  (無料登録)
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Routescan API Key (Avalanche ネットワーク)
# 取得先: https://routescan.io/  (無料登録)
# ※旧 Snowtrace キーも利用可能
ROUTESCAN_API_KEY=your_routescan_api_key_here

# Bitcoin は APIキー不要 (Blockstream.info を使用)
