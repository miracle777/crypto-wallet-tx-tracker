# ============================================================
# クリプト取引履歴トラッカー - API キー設定
# ============================================================
# このファイルをコピーして ".env" という名前で保存し、
# APIキーを設定してください。
# cp .env.example .env
# ============================================================

# ── Etherscan API V2 (Base / Polygon / Ethereum 対応) ───────
# 1つのキーで Base / Polygon を両方カバーします。
#
# 取得先: https://etherscan.io/apidashboard  (無料登録)
#   1. https://etherscan.io/register でアカウント登録
#   2. ログイン後 https://etherscan.io/apidashboard にアクセス
#   3. 「Add」ボタン → App Name を入力 → 作成
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Routescan API (Avalanche 専用) ─────────────────────────
# Avalanche は Etherscan グループ外のため、Routescan の別キーが必要です。
#
# 取得先: https://routescan.io/  (無料登録)
ROUTESCAN_API_KEY=your_routescan_api_key_here

# ── Bitcoin は APIキー不要 (Blockstream.info を使用) ────────
